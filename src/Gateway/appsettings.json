{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "agent-route": {
        "ClusterId": "agent-cluster",
        "Match": {
          "Path": "/api/agent/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "agent-cluster": {
        "Destinations": {
          "agent-destination": {
            "Address": "http://localhost:5001/"
          }
        }
      }
    }
  },
  "RateLimit": {
    "PermitLimit": 100,
    "Window": "00:01:00",
    "QueueLimit": 2
  }
}

